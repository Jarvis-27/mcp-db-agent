# Core runtime
ENVIRONMENT=development
PORT=8000
TRUSTED_PROXY_IPS=127.0.0.1
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Hosted account store
AUTH_DATABASE_URL=sqlite:///./auth.db

# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required outside development. The first key encrypts new secrets; later keys are decrypt-only.
CREDENTIAL_ENCRYPTION_KEYS=

# Public signup gate
REGISTRATION_OPEN=false

# LLM configuration
ANTHROPIC_API_KEY=
GROQ_API_KEY=
LLM_PROVIDER=anthropic
CLAUDE_MODEL=claude-sonnet-4-6
GROQ_MODEL=llama-3.3-70b-versatile
MAX_QUERY_ROWS=100
QUERY_TIMEOUT_SECONDS=30
MAX_SELF_CORRECTION_RETRIES=3
QUERY_POOL_SIZE=64
SCHEMA_CACHE_TTL_SECONDS=600

# User database guardrails
ALLOW_SQLITE_USER_DBS=false
SQLITE_USER_DB_DIR=/var/lib/mcp-db-agent/user-dbs
EXTRA_BLOCKED_CIDRS=

# Request and auth limits
MAX_REQUEST_BYTES=65536
REGISTER_RATE_LIMIT=5/minute
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
LOGIN_LINK_TOKEN_TTL_MINUTES=30
USER_SESSION_TTL_HOURS=24

# Optional future gates
BILLING_GATE_ENABLED=false
MFA_GATE_ENABLED=false

# Optional SMTP delivery; when unset, links are only logged locally.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# ── MCP OAuth resource-server settings ────────────────────────────────────────
# Controls which auth methods are accepted on the public /mcp endpoint.
# Three-step rollout:
#   Step 1 — api_key_only  : bearer mdbk_* API keys only (dev default; no OAuth config needed)
#   Step 2 — hybrid        : OAuth tokens + API keys in parallel; fill OAUTH_* vars below first
#   Step 3 — oauth_only    : OAuth 2.1 access tokens only (production target)
# IMPORTANT: 'hybrid' and 'oauth_only' require OAUTH_AUDIENCE to be set in non-development.
MCP_AUTH_MODE=api_key_only

# Canonical public URL of this MCP resource server.
# Required when MCP_AUTH_MODE != api_key_only.
# Example: https://app.example.com/mcp
MCP_RESOURCE_URL=

# OAuth authorization server / identity provider settings.
# For Auth0: OAUTH_ISSUER_URL=https://YOUR_DOMAIN.auth0.com/
OAUTH_ISSUER_URL=
OAUTH_AUDIENCE=
OAUTH_JWKS_URL=           # optional; defaults to {OAUTH_ISSUER_URL}/.well-known/jwks.json
OAUTH_REQUIRED_SCOPES=mcp:access
OAUTH_HTTP_TIMEOUT_SECONDS=10
OAUTH_JWKS_CACHE_SECONDS=300

# OAuth client for the "Connect MCP account" explicit-linking flow.
# Create an Auth0 "Regular Web Application" and set these values.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=      # leave empty for PKCE-only (public client)
OAUTH_LINK_REDIRECT_URI=  # e.g. https://app.example.com/api/v1/account/mcp-oauth/callback
