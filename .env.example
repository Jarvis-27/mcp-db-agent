# --- Single-tenant mode (default) ---
# Set DATABASE_URL to point at one database. All requests use this DB.
DATABASE_URL = ""

ANTHROPIC_API_KEY = ""
GROQ_API_KEY = ""
LLM_PROVIDER = ""
CLAUDE_MODEL = "claude-sonnet-4-6"
GROQ_MODEL = "llama-3.3-70b-versatile"
MAX_QUERY_ROWS = 100
QUERY_TIMEOUT_SECONDS = 30
MAX_SELF_CORRECTION_RETRIES = 3
TRANSPORT = stdio

# --- Multi-tenant mode ---
# Set MULTI_TENANT=true to serve many users, each with their own database.
# DATABASE_URL is ignored; tenants are managed via: uv run scripts/manage_tenants.py
MULTI_TENANT = false
ENGINE_POOL_MAX_SIZE = 50
ENGINE_POOL_IDLE_SECONDS = 3600