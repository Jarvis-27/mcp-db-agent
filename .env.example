# Core runtime
ENVIRONMENT=development
PORT=8000
TRUSTED_PROXY_IPS=127.0.0.1
CORS_ALLOW_ORIGINS=["http://localhost:3000"]
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Hosted account store
AUTH_DATABASE_URL=postgresql://user:pass@localhost:5432/plainquery_auth

# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required outside development. The first key encrypts new secrets; later keys are decrypt-only.
CREDENTIAL_ENCRYPTION_KEYS=

# Public signup gate
REGISTRATION_OPEN=false

# LLM configuration
ANTHROPIC_API_KEY=
GROQ_API_KEY=
LLM_PROVIDER=anthropic
CLAUDE_MODEL=claude-sonnet-4-6
GROQ_MODEL=llama-3.3-70b-versatile
MAX_QUERY_ROWS=100
QUERY_TIMEOUT_SECONDS=30
MAX_SELF_CORRECTION_RETRIES=3
# Soft per-request LLM cost ceiling (prompt+response chars; ~4 chars/token).
# Self-corrector aborts retries when exceeded.
MAX_LLM_CHARS_PER_REQUEST=40000
QUERY_POOL_SIZE=64
SCHEMA_CACHE_TTL_SECONDS=600

# Per-API-key burst limit for ask_database (in-process counters; multi-worker
# deployments multiply the cap — see CLAUDE.md "Rate-limiter scope").
MCP_BURST_CAPACITY=30
MCP_BURST_WINDOW_SECONDS=60

# User database guardrails
EXTRA_BLOCKED_CIDRS=

# Request and auth limits
MAX_REQUEST_BYTES=65536
REGISTER_RATE_LIMIT=5/minute
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=60
LOGIN_LINK_TOKEN_TTL_MINUTES=30
USER_SESSION_TTL_HOURS=24

# Optional future gates
BILLING_GATE_ENABLED=false
MFA_GATE_ENABLED=false

# Stripe billing
# Use Stripe test mode values in staging. Billing endpoints stay unavailable until
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, and STRIPE_PRO_PRICE_ID are all set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_API_BASE=https://api.stripe.com
# If you override STRIPE_CHECKOUT_SUCCESS_URL, include the Stripe template
# `{CHECKOUT_SESSION_ID}` so the billing page can confirm the session
# immediately (e.g. https://your.app/app/billing?checkout=success&session_id={CHECKOUT_SESSION_ID}).
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_CUSTOMER_PORTAL_RETURN_URL=

# Optional SMTP delivery; when unset, links are only logged locally.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=

# Optional Resend HTTP API delivery (free tier: 100/day, 3000/month).
# Takes precedence over SMTP when both RESEND_API_KEY and RESEND_FROM_ADDRESS are set.
# Get an API key at https://resend.com/api-keys
# To deliver to ANY signup address, verify a sending domain at https://resend.com/domains
# and set RESEND_FROM_ADDRESS to an address on that domain (e.g. "MCP <noreply@yourdomain.com>").
# Without a verified domain, you can still test by using onboarding@resend.dev as the from
# address — but Resend will then only deliver to your own account-owner email.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=

# ── MCP OAuth resource-server settings ────────────────────────────────────────
# Controls which auth methods are accepted on the public /mcp endpoint.
# Three-step rollout:
#   Step 1 — api_key_only  : bearer mdbk_* API keys only (dev default; no OAuth config needed)
#   Step 2 — hybrid        : OAuth tokens + API keys in parallel; fill OAUTH_* vars below first
#   Step 3 — oauth_only    : OAuth 2.1 access tokens only (production target)
# IMPORTANT: 'hybrid' and 'oauth_only' require OAUTH_AUDIENCE to be set in non-development.
MCP_AUTH_MODE=api_key_only

# Canonical public URL of this MCP resource server.
# Required when MCP_AUTH_MODE != api_key_only.
# Example: https://app.example.com/mcp
MCP_RESOURCE_URL=

# OAuth authorization server / identity provider settings.
# For Auth0: OAUTH_ISSUER_URL=https://YOUR_DOMAIN.auth0.com/
OAUTH_ISSUER_URL=
OAUTH_AUDIENCE=
OAUTH_JWKS_URL=           # optional; defaults to {OAUTH_ISSUER_URL}/.well-known/jwks.json
OAUTH_REQUIRED_SCOPES=mcp:access
OAUTH_HTTP_TIMEOUT_SECONDS=10
OAUTH_JWKS_CACHE_SECONDS=300

# OAuth client for the "Connect MCP account" explicit-linking flow.
# Create an Auth0 "Regular Web Application" and set these values.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=      # leave empty for PKCE-only (public client)
OAUTH_LINK_REDIRECT_URI=  # e.g. https://app.example.com/api/v1/account/mcp-oauth/callback

# ── OpenTelemetry tracing (G16) ───────────────────────────────────────────────
# Off by default. When enabled, traces are exported via OTLP to the configured
# endpoint (e.g. an OTel Collector that fans out to Honeycomb / Tempo / Datadog).
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=mcp-db-agent
# OTEL_OTLP_ENDPOINT=http://localhost:4317
# OTEL_OTLP_PROTOCOL=grpc                 # "grpc" or "http"
# OTEL_OTLP_INSECURE=true
# OTEL_SAMPLER_RATIO=1.0                  # 0.0–1.0 (ParentBased TraceIdRatio)
# OTEL_CAPTURE_SQL_TEXT=false             # when true, raw SQL goes on db.statement
